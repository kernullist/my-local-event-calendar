# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용(수집/관리). 절대 클라이언트에 노출 금지

# ── Kakao ─────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=       # 지도 표시용 JavaScript 키. Kakao Developers에 도메인 등록 필요
KAKAO_REST_API_KEY=                 # 지오코딩(주소→좌표) REST 키. 서버 전용

# ── 공공데이터 API ────────────────────────────────────
TOURAPI_SERVICE_KEY=                # 공공데이터포털 TourAPI 서비스키
SEOUL_OPENAPI_KEY=                  # 서울 열린데이터광장 인증키

# ── Cron 보호 ─────────────────────────────────────────
CRON_SECRET=                        # /api/ingest/*, /api/verify-status 호출 검증용 임의 문자열
