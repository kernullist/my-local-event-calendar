# 사용법: 이 파일을 .env.local 로 복사한 뒤, 각 줄의 = 뒤에 "값만" 붙여넣으세요.
#   올바름:  SEOUL_OPENAPI_KEY=abcd1234...
#   잘못됨:  SEOUL_OPENAPI_KEY=          # 서울 인증키   ← 주석이 값으로 들어감

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role(secret) — 서버 전용. 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# ── VWorld (지오코딩) ─────────────────────────────────
# 국토부 공간정보 오픈플랫폼 인증키. 서버 전용(주소→좌표). vworld.kr 에서 개인 무료 발급
# 지도(M4)는 Leaflet+OpenStreetMap 으로 키 없이 표시 예정
VWORLD_API_KEY=

# ── 공공데이터 API ────────────────────────────────────
# 공공데이터포털 TourAPI 서비스키 — 반드시 "Decoding" 키 사용
TOURAPI_SERVICE_KEY=
# 서울 열린데이터광장 인증키
SEOUL_OPENAPI_KEY=
# 문화포털(문화공공데이터광장, culture.go.kr) 공연전시 API 키
CULTURE_API_KEY=

# ── Cron 보호 ─────────────────────────────────────────
# /api/ingest/*, /api/verify-status 호출 검증용 임의 문자열
CRON_SECRET=
